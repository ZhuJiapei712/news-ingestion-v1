{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.quant-news-agent/schemas/article_record.schema.json",
  "title": "ArticleRecord",
  "type": "object",
  "additionalProperties": true,
  "required": ["article_id", "source", "title", "url", "crawled_at", "quality_score", "status"],
  "properties": {
    "article_id": {
      "type": "string",
      "description": "Stable SHA-256 identifier generated from source and URL or source, title and time."
    },
    "source": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "source_tier": {
      "type": "string",
      "enum": ["T0", "T1", "T2", "T3", "UNKNOWN"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": ["string", "null"]
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "published_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "crawled_at": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": ["string", "null"]
    },
    "section": {
      "type": ["string", "null"]
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw_html_path": {
      "type": ["string", "null"]
    },
    "hot_features": {
      "type": "object",
      "description": "Hotness and engagement features captured from the source when available.",
      "additionalProperties": true,
      "properties": {
        "source_prominence": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "list_rank": { "type": ["integer", "null"] },
            "list_size": { "type": ["integer", "null"] },
            "source_priority": { "type": ["integer", "null"] },
            "source_tier": { "type": ["string", "null"] },
            "entrypoint": { "type": ["string", "null"] },
            "captured_at": { "type": ["string", "null"], "format": "date-time" }
          }
        },
        "engagement_metrics": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "read_count": { "type": ["integer", "null"] },
            "view_count": { "type": ["integer", "null"] },
            "comment_count": { "type": ["integer", "null"] },
            "like_count": { "type": ["integer", "null"] },
            "favorite_count": { "type": ["integer", "null"] },
            "share_count": { "type": ["integer", "null"] },
            "repost_count": { "type": ["integer", "null"] },
            "collected_at": { "type": ["string", "null"], "format": "date-time" },
            "available_fields": { "type": "array", "items": { "type": "string" } },
            "missing_fields": { "type": "array", "items": { "type": "string" } },
            "quality_flags": { "type": "array", "items": { "type": "string" } },
            "raw": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    "content_hash": {
      "type": ["string", "null"]
    },
    "title_hash": {
      "type": ["string", "null"]
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["valid", "review", "rejected"]
    }
  }
}
